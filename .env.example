# Spoonacular API
# https://spoonacular.com/food-api/console#Dashboard
VITE_SPOONACULAR_KEY=dein-key-hier

# Optional: statt Live-API lokale Mock-Daten verwenden (empfohlen während der Entwicklung,
# um das 150 Punkte/Tag Kontingent zu schonen).
# Werte: "true" | "false" — wird auch als aktiv behandelt, wenn kein API-Key gesetzt ist.
VITE_USE_MOCKS=false
